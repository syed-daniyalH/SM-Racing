# Local development proxies browser requests through Next.js, then to FastAPI.
NEXT_PUBLIC_API_URL=/api/v1
SM2_API_PROXY_TARGET=http://127.0.0.1:8000

# In Vercel production, either keep NEXT_PUBLIC_API_URL=/api/v1 and set
# SM2_API_PROXY_TARGET to the Render backend, or point the browser directly:
# NEXT_PUBLIC_API_URL=https://sm-racing-api.onrender.com/api/v1
